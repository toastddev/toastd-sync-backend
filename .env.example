PORT=8787
DASHBOARD_PASSWORD=changeme
JWT_SECRET=replace-with-long-random-string
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
FIRESTORE_PROJECT_ID=toastd
# Optional override of the cron schedule (default every 30 min)
SYNC_CRON=*/30 * * * *
# Drift check cron (default every hour at :15) — re-checks already-synced products
# for regressions (mapped/partial -> unmapped) without creating new ones.
DRIFT_CRON=15 * * * *
